# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# Used by scripts/smoke_test_provider.py for a real LLM API call.
# Named provider-agnostically since OpenAICompatibleProvider works with
# Gemini, Groq, OpenRouter, self-hosted Ollama/vLLM, etc.
AI_API_KEY=

# Model ID to use for the smoke test. Kept configurable rather than
# hardcoded — preview/free-tier model availability shifts often
# (e.g. gemini-2.5-flash became unavailable to new accounts;
# gemini-3-flash-preview is a current alternative as of July 2026).
MODEL_ID=gemini-3-flash-preview

# Used when testing against a real GitHub repo/PR locally (not needed for
# the mocked test suite — pytest never hits real GitHub or LLM APIs).
GITHUB_TOKEN=
